# Google Search Console: Verifizierungs-Token (nur der Wert aus dem meta-Tag, ohne Anführungszeichen).
# GOOGLE_SITE_VERIFICATION=abc123xyz

# Optional: nur wenn gesetzt, schützt /admin/bilder mit Login (Wert = „Passwort“).
# Weglassen = Dashboard direkt unter http://localhost:3000/admin/bilder (nur lokal sinnvoll).
# ADMIN_MEDIA_SECRET=ändern-zu-langem-geheimen-string

# Kontaktformular: SMTP-Zugang für den Versand an info@greenguard-msh.de.
# Diese Werte müssen in .env.local gesetzt werden und dürfen nicht öffentlich committed werden.
# SMTP_HOST=smtp.example.de
# SMTP_PORT=587
# SMTP_USER=info@greenguard-msh.de
# SMTP_PASS=mailbox-passwort-oder-app-passwort
# SMTP_FROM="Green Guard GmbH <info@greenguard-msh.de>"
# CONTACT_MAIL_TO=info@greenguard-msh.de
#
# Spam-Schutz: zusätzlich sind serverseitig Origin-Prüfung, Honeypot,
# Zeitprüfung, Feldlängen, Linklimit und ein Rate-Limit aktiv.
